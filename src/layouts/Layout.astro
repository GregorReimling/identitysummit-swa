---
import '../styles/global.css';

const { 
    title = "Cloud Identity Summit 2026",
    description = "The community conference for cloud identity professionals. Join us on November 3, 2026, in Frankfurt, Germany for deep insights on identity, security, and access management.",
    image = "/social-share.jpg"
} = Astro.props;

const pathname = Astro.url.pathname;
const currentPath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

const site = Astro.site || new URL("https://www.identitysummit.cloud");
const canonicalURL = new URL(pathname, site);
const socialImageURL = new URL(image, site);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
</head>
<body class="bg-slate-950 text-slate-200 font-sans antialiased min-h-screen flex flex-col">

<nav class="w-full max-w-7xl mx-auto px-4 py-6 flex justify-between items-center relative z-50">
<a href="/" class="flex items-center">
    <img src="/images/cislogo.svg" alt="Cloud Identity Summit Logo" class="h-10 w-auto hover:opacity-80 transition-opacity" />
</a>
    <div class="md:hidden">
    <a href="/" class="flex justify-center mb-8">
        <img src="/images/cislogo.svg" alt="Cloud Identity Summit Logo" class="h-10 w-auto" />
    </a>
    </div>
    
    <!-- Desktop Menü -->
    <div class="hidden md:flex gap-8 items-center">
        <a href="/agenda" class="text-slate-300 hover:text-white transition">Agenda</a>
        <a href="/team" class="text-slate-300 hover:text-white transition">Team</a>
        <a href="/call-for-sponsors" class="text-slate-300 hover:text-white transition">Sponsors</a>
        <a href="/tickets" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg transition">Tickets</a>
    </div>

    <!-- Mobile Burger Button -->
    <button id="menu-btn" class="md:hidden text-white p-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
    </button>
</nav>

<!-- Mobile Overlay Menü -->
<div id="mobile-menu" class="hidden md:hidden absolute top-20 left-0 w-full bg-slate-950/95 border-b border-slate-800 p-8 flex flex-col gap-6 text-center z-40">
    <a href="/agenda" class="text-xl text-white">Agenda</a>
    <a href="/team" class="text-xl text-white">Team</a>
    <a href="/call-for-sponsors" class="text-xl text-white">Sponsors</a>
    <a href="/tickets" class="bg-blue-600 text-white px-6 py-3 rounded-lg">Tickets</a>
</div>

<script is:inline>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
    });
</script>

    <slot />

    <footer class="border-t border-slate-900 bg-slate-950 py-10 mt-auto">
        <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-slate-500">
            <span>© 2026 Cloud Identity Summit</span>
            <div class="flex gap-8">
                <a href="/impressum" class="hover:text-slate-300 transition">Impressum</a>
                <a href="/datenschutz" class="hover:text-slate-300 transition">Datenschutz</a>
                <a href="/code-of-conduct" class="hover:text-slate-300 transition">Code of Conduct</a>
            </div>
        </div>
    </footer>
</body>
</html>