---
import '../styles/global.css';
import Footer from '../components/Footer.astro'; 

const { 
    title = "Cloud Identity Summit 2026",
    description = "The community conference for cloud identity professionals. Join us on November 3, 2026, in Frankfurt, Germany for deep insights on identity, security, and access management.",
    image = "/social-share.jpg"
} = Astro.props;

const pathname = Astro.url.pathname;
const site = Astro.site || new URL("https://www.identitysummit.cloud");
const canonicalURL = new URL(pathname, site);
const socialImageURL = new URL(image, site);
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
</head>
<body class="bg-slate-950 text-slate-200 font-sans antialiased min-h-screen flex flex-col">

    <nav class="w-full max-w-7xl mx-auto px-6 py-8 flex justify-between items-center relative z-50">
        <a href="/" class="flex items-center">
            <img src="/images/cislogo.svg" alt="Logo" class="h-12 w-auto hover:opacity-80 transition-opacity" />
        </a>
        
<div class="hidden md:flex gap-10 items-center">
            <a href="/agenda" class="text-slate-200 hover:text-white transition text-lg font-medium">Agenda</a>
            <a href="/speaker" class="text-slate-200 hover:text-white transition text-lg font-medium">Speakers</a>
            <a href="/team" class="text-slate-200 hover:text-white transition text-lg font-medium">Team</a>
            <a href="/sponsors" class="text-slate-200 hover:text-white transition text-lg font-medium">Sponsors</a>
            <div class="relative group">
                <span class="text-slate-200 hover:text-white transition text-lg font-medium cursor-pointer">Past Summits ▾</span>
                <div class="absolute top-full left-0 mt-2 hidden group-hover:flex flex-col bg-slate-900 border border-slate-800 rounded-xl p-2 min-w-48 z-50">
                    {[2025, 2024, 2023, 2022, 2021, 2020].map(year => (
                        <a href={`/archive/${year}`} class="px-4 py-2 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg text-sm whitespace-nowrap">
                            Cloud Identity Summit {year}
                        </a>
                    ))}
                </div>
            </div>
            <a href="/venue" class="text-slate-200 hover:text-white transition text-lg font-medium">Venue</a>
            <a href="/tickets" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-lg transition text-lg font-semibold">Tickets</a>
        </div>

        <button id="menu-btn" class="md:hidden text-white p-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
        </button>
    </nav>

<div id="mobile-menu" class="hidden md:hidden absolute top-24 left-0 w-full bg-slate-950/95 border-b border-slate-800 p-8 flex flex-col gap-6 text-center z-40">
        <a href="/agenda" class="text-2xl text-white font-medium">Agenda</a>
        <a href="/speaker" class="text-2xl text-white font-medium">Speakers</a>
        <a href="/team" class="text-2xl text-white font-medium">Team</a>
        <a href="/sponsors" class="text-2xl text-white font-medium">Sponsors</a>
        <a href="/venue" class="text-2xl text-white font-medium">Venue</a>
        <div class="flex flex-col gap-3">
            <span class="text-sm text-slate-500 uppercase tracking-widest">Past Summits</span>
            {[2025, 2024, 2023, 2022, 2021, 2020].map(year => (
                <a href={`/archive/${year}`} class="text-lg text-slate-300 font-medium">CIS {year}</a>
            ))}
        </div>
        <a href="/tickets" class="bg-blue-600 text-white px-6 py-4 rounded-xl text-xl font-semibold mt-2">Tickets</a>
    </div>

    <script is:inline>
        const btn = document.getElementById('menu-btn');
        const menu = document.getElementById('mobile-menu');
        btn.addEventListener('click', () => { menu.classList.toggle('hidden'); });
    </script>

    <main class="flex-grow">
        <slot />
    </main>

    <footer class="border-t border-slate-900 bg-slate-950 py-10 mt-auto">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-slate-500">
            <span>© 2026 Cloud Identity Summit</span>
            <div class="flex gap-8">
                <a href="/impressum" class="hover:text-slate-300 transition">Impressum</a>
                <a href="/datenschutz" class="hover:text-slate-300 transition">Datenschutz</a>
                <a href="/code-of-conduct" class="hover:text-slate-300 transition">Code of Conduct</a>
            </div>
        </div>
    </footer>
</body>
</html>