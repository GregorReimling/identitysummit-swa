---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/nav.astro';
import Footer from '../components/footer.astro';
---

<BaseLayout title="Agenda" description="Cloud Identity Summit 2026 – Full Schedule">
  <Nav />
  <main class="main">
    <div class="container">

      <div class="page-header">
        <div class="page-label">Schedule</div>
        <h1 class="page-title">Agenda 2026</h1>
        <p class="page-sub">3. November 2026 · Frankfurt, Germany</p>
      </div>

      <div class="sessionize-wrap">
        <script
          is:inline
          type="text/javascript"
          src="https://sessionize.com/api/v2/zypgzww2/view/GridSmart"
        ></script>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .main { padding: 100px 0 80px; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  .page-header { margin-bottom: 48px; }
  .page-label {
    font-family: var(--font-display); font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: #6c8fff; margin-bottom: 12px;
  }
  .page-title {
    font-family: var(--font-display); font-size: clamp(32px, 5vw, 56px);
    font-weight: 800; color: var(--text-high); margin-bottom: 8px;
  }
  .page-sub { font-size: 16px; font-weight: 300; color: var(--text-mid); }

  .sessionize-wrap {
    background: var(--bg-card);
    border: 1px solid rgba(120,120,200,0.15);
    border-radius: 16px;
    padding: 32px;
    overflow-x: auto;
  }

  /* Sessionize Widget Dark Mode Overrides */
  .sessionize-wrap :global(.sz-root) { color: var(--text-high) !important; }
  .sessionize-wrap :global(.sz-session) {
    background: var(--bg-raised) !important;
    border-color: rgba(120,120,200,0.2) !important;
    border-radius: 8px !important;
  }
  .sessionize-wrap :global(.sz-session:hover) {
    border-color: rgba(108,143,255,0.4) !important;
  }
  .sessionize-wrap :global(.sz-session--title) { color: var(--text-high) !important; }
  .sessionize-wrap :global(.sz-session--speakers) { color: var(--text-mid) !important; }
  .sessionize-wrap :global(.sz-time-slot) { color: var(--text-low) !important; }
</style>