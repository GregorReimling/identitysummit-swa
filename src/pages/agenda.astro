---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Agenda | Cloud Identity Summit">
    <main class="max-w-3xl mx-auto px-4 py-32 w-full flex-grow text-center">
        <div class="inline-block bg-blue-900/30 border border-blue-800/50 rounded-full px-4 py-1.5 mb-6">
            <span class="text-blue-400 text-sm font-semibold tracking-wide uppercase">Schedule</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-8">
            Agenda 2026
        </h1>
        
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-8 md:p-12 backdrop-blur-sm relative overflow-hidden">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl pointer-events-none"></div>
            
            <div class="relative z-10">
                <div class="text-6xl mb-6">🗓️</div>
                <h2 class="text-2xl font-bold text-white mb-4">Program under construction</h2>
                <p class="text-slate-400 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
                    We are putting together an incredible lineup of cloud identity experts for you. The full schedule will be published here once the Call for Speakers has concluded.
                </p>
                
                <div class="bg-slate-950/50 border border-slate-800 rounded-xl p-6 mt-8">
                    <h3 class="text-lg font-bold text-white mb-2">Want to speak at CIS 2026?</h3>
                    <p class="text-slate-400 text-sm mb-4">Our Call for Speakers will open in a few months. Stay tuned!</p>
                    <p class="text-sm text-slate-500 pt-4 border-t border-slate-800">
                        Questions? Reach out to: <span id="speaker-mail-placeholder" class="font-mono text-blue-400">[Protected Email]</span>
                    </p>
                </div>
            </div>
        </div>
    </main>

    <!-- Bot-Schutz Script für die Speaker E-Mail -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const user = 'speakers';
            const domain = 'identitysummit.cloud';
            const element = document.getElementById('speaker-mail-placeholder');
            if (element) {
                element.innerHTML = `<a href="mailto:${user}@${domain}" class="hover:underline text-blue-400">${user}@${domain}</a>`;
            }
        });
    </script>
</Layout>