---
import Layout from '../../layouts/Layout.astro';

const imgBase = "https://identitysummitfiles.blob.core.windows.net/cis-images";
---

<Layout title="Archive 2025 | Cloud Identity Summit">
    <main class="max-w-5xl mx-auto px-4 py-20">
        <h1 class="text-4xl font-bold text-white mb-2">Cloud Identity Summit 2025</h1>
        <p class="text-slate-400 mb-10">Thursday, September 4, 2025 | Dortmund</p>
        
        <div class="space-y-8">
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center font-bold text-blue-400">08:30 am - Doors Open</div>

            <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                <span class="text-slate-500 text-sm">09:00 am</span>
                <h3 class="text-xl font-bold text-white">Past, Present, and Future: Identity at the Crossroads of Cyber Risk and Microsoft’s Cloud Vision</h3>
                <p class="text-slate-400">Guido Grillenmeier</p>
            </div>

            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center text-slate-400">09:30 am - Welcome and Orga Session</div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">09:50 am</span>
                    <h3 class="text-lg font-bold text-white mb-1">Mastering Identity with Entra ID: Regain the Control !</h3>
                    <p class="text-slate-400 text-sm">Morten Knudsen</p>
                </div>
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">09:50 am</span>
                    <h3 class="text-lg font-bold text-white mb-1">Hacking into Entra using Project Blackcat</h3>
                    <p class="text-slate-400 text-sm">Rogier Dijkman</p>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center text-slate-400">10:40 am - Break</div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">11:00 am</span>
                    <h3 class="text-lg font-bold text-white mb-1">Is Entra Connect Sync Still the Best Choice?</h3>
                    <p class="text-slate-400 text-sm">Christopher Brumm, Fabian Bader</p>
                </div>
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">11:00 am</span>
                    <h3 class="text-lg font-bold text-white mb-1">Hack your protected API for integration testing</h3>
                    <p class="text-slate-400 text-sm">Stephan van Rooij</p>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center text-slate-400">11:55 am - Sponsor Sessions</div>

            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center font-bold text-blue-400">12:40 pm - Lunch Break</div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">01:30 pm</span>
                    <h3 class="text-lg font-bold text-white mb-1">Entra ID External Identities</h3>
                    <p class="text-slate-400 text-sm">Jan Vidar Elven</p>
                </div>
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">01:30 pm</span>
                    <h3 class="text-lg font-bold text-white mb-1">Game Theory for Disrupting Dormant Identities</h3>
                    <p class="text-slate-400 text-sm">Joshua Bahirvani, Shaleen Dev P.K.</p>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">02:30 pm</span>
                    <h3 class="text-lg font-bold text-white mb-1">Entra ID Applications: Five Do’s and Don’ts</h3>
                    <p class="text-slate-400 text-sm">Sander Berkouwer, Raymond Comvalius</p>
                </div>
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">02:30 pm</span>
                    <h3 class="text-lg font-bold text-white mb-1">Lessons learned from Conditional Access</h3>
                    <p class="text-slate-400 text-sm">Kenneth van Surksum</p>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center text-slate-400">03:20 pm - Break</div>

            <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">03:40 pm</span>
                    <h3 class="text-lg font-bold text-white mb-1">Identity Security on Autopilot</h3>
                    <p class="text-slate-400 text-sm">Michael Van Horenbeeck</p>
                </div>
                <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800">
                    <span class="text-slate-500 text-sm">03:40 pm</span>
                    <h3 class="text-lg font-bold text-white mb-1">Deep-dive to Entra ID Token Theft Protection</h3>
                    <p class="text-slate-400 text-sm">Nestori Syynimaa</p>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center font-bold text-blue-400">04:30 pm - AMA & Roundtable</div>
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center text-slate-400">05:00 pm - Closing / Happy Hour</div>
        </div>
    </main>
</Layout>