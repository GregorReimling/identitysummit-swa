---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Call for Sponsors | Cloud Identity Summit 2026">
    <!-- Hero Section mit abstraktem Glow-Effekt -->
    <section class="relative pt-32 pb-20 px-4 overflow-hidden flex-grow">
        <!-- Dekorative Hintergrund-Leuchteffekte -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[500px] bg-gradient-to-b from-blue-900/40 via-blue-900/10 to-transparent blur-3xl pointer-events-none"></div>
        
        <div class="relative z-10 max-w-4xl mx-auto text-center">
            <div class="inline-block bg-amber-900/30 border border-amber-700/50 rounded-full px-4 py-1.5 mb-6 animate-fade-in-up">
                <span class="text-amber-500 text-sm font-semibold tracking-wider uppercase">Partnership Opportunities</span>
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight leading-tight mb-8">
                Empower the <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-yellow-500 to-amber-600">Identity Community</span>
            </h1>
            
            <p class="text-xl text-slate-300 mb-12 max-w-2xl mx-auto leading-relaxed">
                Join us as a sponsor for the Cloud Identity Summit 2026 in Frankfurt. Showcase your brand to leading architects, engineers, and decision-makers in the cloud security space.
            </p>
        </div>
    </section>

    <!-- Why Sponsor Section (SEO optimierter Text) -->
    <main class="max-w-6xl mx-auto px-4 pb-32 w-full relative z-10">
        
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Why Sponsor CIS 2026?</h2>
            <p class="text-slate-400 max-w-2xl mx-auto text-lg">
                Our conference is 100% community-driven and free for attendees. Your sponsorship directly enables knowledge sharing and industry networking at the highest level.
            </p>
        </div>

        <!-- 3-Spalten Grid mit Hover-Animationen -->
        <div class="grid md:grid-cols-3 gap-8 mb-24">
            <!-- Card 1 -->
            <div class="group bg-slate-900/60 backdrop-blur-xl border border-slate-800 rounded-3xl p-8 hover:border-blue-500/50 hover:bg-slate-800/80 transition-all duration-500 hover:-translate-y-2 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl group-hover:bg-blue-500/20 transition-all duration-500"></div>
                <div class="text-4xl mb-6 group-hover:scale-110 transition-transform duration-300 origin-left">🎯</div>
                <h3 class="text-xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors">Targeted Audience</h3>
                <p class="text-slate-400 leading-relaxed text-sm">
                    Connect directly with a highly specialized audience of Microsoft Entra ID experts, cloud security architects, and IT decision-makers who are actively looking for solutions.
                </p>
            </div>

            <!-- Card 2 -->
            <div class="group bg-slate-900/60 backdrop-blur-xl border border-slate-800 rounded-3xl p-8 hover:border-amber-500/50 hover:bg-slate-800/80 transition-all duration-500 hover:-translate-y-2 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-amber-500/10 rounded-full blur-3xl group-hover:bg-amber-500/20 transition-all duration-500"></div>
                <div class="text-4xl mb-6 group-hover:scale-110 transition-transform duration-300 origin-left">🚀</div>
                <h3 class="text-xl font-bold text-white mb-3 group-hover:text-amber-400 transition-colors">Brand Visibility</h3>
                <p class="text-slate-400 leading-relaxed text-sm">
                    Benefit from premium logo placement, dedicated sponsor booths, and active mentions across our social media channels, website, and during the event keynotes.
                </p>
            </div>

            <!-- Card 3 -->
            <div class="group bg-slate-900/60 backdrop-blur-xl border border-slate-800 rounded-3xl p-8 hover:border-emerald-500/50 hover:bg-slate-800/80 transition-all duration-500 hover:-translate-y-2 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl group-hover:bg-emerald-500/20 transition-all duration-500"></div>
                <div class="text-4xl mb-6 group-hover:scale-110 transition-transform duration-300 origin-left">🤝</div>
                <h3 class="text-xl font-bold text-white mb-3 group-hover:text-emerald-400 transition-colors">Community Impact</h3>
                <p class="text-slate-400 leading-relaxed text-sm">
                    Position your company as a true supporter of the IT community. Your financial contribution is exactly what keeps this high-quality event free and accessible for all attendees.
                </p>
            </div>
        </div>

        <!-- Call to Action & Download Box -->
        <div class="bg-gradient-to-br from-slate-900 to-slate-950 border border-slate-700/50 rounded-[2.5rem] p-8 md:p-16 text-center relative overflow-hidden shadow-2xl">
            <!-- Animierter Hintergrund Glow in der CTA Box -->
            <div class="absolute -inset-x-4 -inset-y-4 z-0 bg-gradient-to-r from-blue-600/10 via-amber-500/10 to-cyan-500/10 blur-2xl opacity-70 animate-pulse pointer-events-none"></div>
            
            <div class="relative z-10">
                <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Ready to join us?</h2>
                <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
                    We offer multiple sponsorship tiers (Gold, Silver, and Bronze) tailored to fit your marketing goals and budget. Download our full sponsorship deck for detailed pricing, booth sizes, and benefits.
                </p>
                
                <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
                    <!-- Link auf dein bereitgestelltes PDF -->
                    <a href="/docs/CIS_Sponsorship_2026.pdf" target="_blank" class="group relative inline-flex items-center gap-3 bg-amber-600 hover:bg-amber-500 text-white px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-[0_0_20px_rgba(217,119,6,0.4)] hover:shadow-[0_0_30px_rgba(217,119,6,0.6)] hover:-translate-y-1">
                        <svg class="w-6 h-6 group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        Download Sponsorship Deck
                    </a>
                </div>
                
                <div class="mt-12 pt-8 border-t border-slate-800/60">
                    <p class="text-slate-400 mb-2">Have custom requirements or questions?</p>
                    <!-- Bot-geschützte E-Mail für direkten Kontakt -->
                    <p class="text-lg">Drop us a line at: <span id="sponsor-mail-placeholder" class="font-mono text-blue-400 font-semibold tracking-wide">[Protected Email]</span></p>
                </div>
            </div>
        </div>

    </main>

    <!-- Bot-Schutz Script für E-Mail -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const user = 'info';
            const domain = 'identitysummit.cloud';
            const element = document.getElementById('sponsor-mail-placeholder');
            if (element) {
                element.innerHTML = `<a href="mailto:${user}@${domain}?subject=Sponsorship%20Inquiry%20CIS%202026" class="hover:text-blue-300 transition-colors">${user}@${domain}</a>`;
            }
        });
    </script>
</Layout>