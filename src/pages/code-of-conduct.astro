---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Code of Conduct | Cloud Identity Summit">
    <main class="max-w-4xl mx-auto px-4 py-20 w-full flex-grow">
        <div class="text-blue-500 text-sm font-bold tracking-wider uppercase mb-3">Guidelines</div>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-8">Code of Conduct</h1>
        <div class="text-slate-300 leading-relaxed space-y-6">
            <p>Our Code of Conduct content will be placed here.</p>
        </div>
    </main>
</Layout>