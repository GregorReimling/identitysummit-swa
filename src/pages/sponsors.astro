---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sponsors | Cloud Identity Summit">
    <main class="max-w-4xl mx-auto px-4 py-20 w-full flex-grow">
        <div class="text-blue-500 text-sm font-bold tracking-wider uppercase mb-3">Our Partners</div>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-16">Sponsors</h1>
        
        <section class="mb-20">
            <h2 class="text-3xl font-bold text-yellow-500 mb-8 border-b border-slate-800 pb-4">Gold Sponsors</h2>
            <div class="space-y-12">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-3"><a href="https://www.adesso.de/en" target="_blank" class="hover:text-blue-400 transition">adesso SE</a></h3>
                    <p class="text-slate-400 leading-relaxed">Business success is the result of innovative ideas, forward-looking strategies and perfectly tailored IT solutions. With a team of around 6.300 employees on 56 sites, we are one of the leading IT service providers in the German-speaking area.</p>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-white mb-3"><a href="https://www.glueckkanja.com/en" target="_blank" class="hover:text-blue-400 transition">glueckkanja AG</a></h3>
                    <p class="text-slate-400 leading-relaxed">glueckkanja, a renowned Cloud Managed Service Provider, is a Microsoft partner offering comprehensive cloud solutions. With a unified blueprint approach, glueckkanja uses Infrastructure as Code to transition and support customer infrastructures.</p>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-white mb-3"><a href="https://www.token2.com/" target="_blank" class="hover:text-blue-400 transition">TOKEN2</a></h3>
                    <p class="text-slate-400 leading-relaxed">Token2 is a cybersecurity company specializing in multifactor authentication. Alongside legacy OTP-based hardware tokens and standard FIDO2 keys, Token2 offers the innovative PIN+ series.</p>
                </div>
                <div>
                    <h3 class="text-2xl font-bold text-white mb-3"><a href="https://tenantmanager.com/" target="_blank" class="hover:text-blue-400 transition">SoftwareCentral | Tenant Manager</a></h3>
                    <p class="text-slate-400 leading-relaxed">SoftwareCentral’s Tenant Manager enhances Microsoft Intune with enterprise-grade governance, automates change controls, and delivers granular oversight across multi-tenant environments.</p>
                </div>
            </div>
        </section>

        <section class="mb-20">
            <h2 class="text-3xl font-bold text-slate-300 mb-8 border-b border-slate-800 pb-4">Silver Sponsors</h2>
            <div class="space-y-12">
                <div class="bg-slate-900/40 border border-slate-800 p-6 rounded-xl text-center">
                    <p class="text-slate-500 italic">No Silver Sponsors yet.</p>
                    <a href="/call-for-sponsors" class="text-blue-500 hover:text-blue-400 text-sm font-semibold mt-2 inline-block">Become a sponsor →</a>
                </div>
            </div>
        </section>

        <section>
            <h2 class="text-3xl font-bold text-amber-600 mb-8 border-b border-slate-800 pb-4">Bronze Sponsors</h2>
            <div class="space-y-12">
                <div>
                    <h3 class="text-2xl font-bold text-white mb-3">BuildClouds</h3>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>