---
import Layout from '../layouts/Layout.astro';
---


<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Cloud Identity Summit 2026",
  "startDate": "2026-11-03",
  "location": {
    "@type": "Place",
    "name": "Frankfurt am Main",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Frankfurt",
      "addressCountry": "DE"
    }
  },
  "description": "The community conference for cloud identity professionals. Deep insights on identity, security, and access management.",
  "organizer": {
    "@type": "Organization",
    "name": "Cloud Identity Summit Team"
  }
}
</script>

<Layout title="Cloud Identity Summit 2026">
    <!-- HERO BEREICH START -->
    <section class="relative pt-24 pb-16 md:pt-32 md:pb-24 px-4 text-center flex-grow bg-cover bg-center" style="background-image: url('/images/frankfurt-skyline.jpg');">
        
        <div class="absolute inset-0 bg-gradient-to-b from-slate-950/40 via-slate-950/70 to-slate-950"></div>

        <div class="relative z-10 max-w-4xl mx-auto">
            <div class="text-blue-400 font-mono text-sm mb-6 tracking-wider uppercase drop-shadow-md">
                Cloud Identity Summit 2026 · Frankfurt
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight leading-tight mb-6 drop-shadow-lg">
                Identity.<br/>
                Security.<br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">2026.</span>
            </h1>
            
            <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto drop-shadow">
                The community conference for cloud identity professionals.
            </p>

            <div class="flex justify-center items-center gap-8 text-sm font-medium text-slate-300 mb-12">
                <div class="flex flex-col items-center">
                    <span class="text-slate-400 text-xs uppercase tracking-wider mb-1">Date</span>
                    <span class="text-white">November 3, 2026</span>
                </div>
                <div class="w-px h-8 bg-slate-700"></div>
                <div class="flex flex-col items-center">
                    <span class="text-slate-400 text-xs uppercase tracking-wider mb-1">Location</span>
                    <span class="text-white">Frankfurt, Germany</span>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
                <a href="/tickets" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3.5 rounded-lg font-semibold transition shadow-lg">🎟 Get Tickets</a>
                <a href="/agenda" class="bg-slate-900/80 border border-slate-700 hover:bg-slate-800 text-white px-8 py-3.5 rounded-lg font-semibold transition backdrop-blur-md">View Agenda</a>
            </div>

            <div id="countdown" class="flex justify-center gap-4 text-center font-mono drop-shadow-xl hidden">
                <div class="bg-slate-900/80 border border-slate-700/50 rounded-xl p-4 min-w-[90px] backdrop-blur-md">
                    <span id="cd-days" class="block text-3xl font-bold text-white mb-1">--</span>
                    <span class="text-xs text-slate-400 uppercase tracking-wider">Days</span>
                </div>
                <div class="text-2xl font-bold text-slate-500 self-center">:</div>
                <div class="bg-slate-900/80 border border-slate-700/50 rounded-xl p-4 min-w-[90px] backdrop-blur-md">
                    <span id="cd-hours" class="block text-3xl font-bold text-white mb-1">--</span>
                    <span class="text-xs text-slate-400 uppercase tracking-wider">Hours</span>
                </div>
                <div class="text-2xl font-bold text-slate-500 self-center">:</div>
                <div class="bg-slate-900/80 border border-slate-700/50 rounded-xl p-4 min-w-[90px] backdrop-blur-md">
                    <span id="cd-mins" class="block text-3xl font-bold text-white mb-1">--</span>
                    <span class="text-xs text-slate-400 uppercase tracking-wider">Minutes</span>
                </div>
            </div>
        </div>
    </section>
    <!-- HERO BEREICH ENDE -->


    <!-- NEU: SPONSOREN TICKER START -->
    <section class="py-12 border-y border-slate-800/50 bg-slate-900/20 overflow-hidden relative">
        <div class="absolute top-0 left-0 w-32 h-full bg-gradient-to-r from-slate-950 to-transparent z-10 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-32 h-full bg-gradient-to-l from-slate-950 to-transparent z-10 pointer-events-none"></div>
        
        <p class="text-center text-slate-500 text-sm font-semibold uppercase tracking-widest mb-8">
            Trusted by industry leaders in previous years
        </p>

        <div class="flex w-[200%] animate-scroll hover:[animation-play-state:paused] items-center">
            <div class="flex w-1/2 justify-around items-center px-4">
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">adesso SE</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">glueckkanja</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">Yubico</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">Microsoft</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">Skill AS</span>
            </div>
            <div class="flex w-1/2 justify-around items-center px-4">
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">adesso SE</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">glueckkanja</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">Yubico</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">Microsoft</span>
                <span class="text-2xl font-bold text-slate-400 opacity-50 hover:opacity-100 hover:text-white transition-all cursor-default">Skill AS</span>
            </div>
        </div>
    </section>
    <!-- NEU: SPONSOREN TICKER ENDE -->


    <main class="max-w-4xl mx-auto px-4 py-20 w-full">
        <section class="mb-24">
            <div class="text-blue-500 text-sm font-bold tracking-wider uppercase mb-3">About the Event</div>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">What is the Cloud Identity Summit?</h2>
            
            <div class="text-slate-300 text-lg leading-relaxed">
                <p class="mb-6">
                    The Cloud Identity Summit focuses on Cloud Identity Management — identity protection, managing external accounts, passwordless authentication and much more. It is a free community event that brings together an international group of participants from different areas and industries, with a focus on knowledge exchange.
                </p>
                <p class="mb-10">
                    The Cloud Identity Summit 2026 will take place on <strong class="text-white font-semibold">3. November 2026</strong> in Frankfurt. We are looking for sponsors and partners who support us — without them, we would not be able to offer this conference for free.
                </p>
            </div>

            <div class="flex flex-wrap gap-4">
                <a href="/tickets" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-3 rounded-lg font-semibold transition">🎟 Get Tickets</a>
                <a href="/call-for-sponsors" class="bg-slate-800 border border-slate-700 hover:bg-slate-700 text-white px-6 py-3 rounded-lg font-semibold transition">Become a Sponsor</a>
            </div>
        </section>

        <section>
            <div class="text-blue-500 text-sm font-bold tracking-wider uppercase mb-3">Archive</div>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Past Events</h2>
            
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                {['2025', '2024', '2023', '2022', '2021', '2020'].map((year) => (
                    <a href={`/archive/${year}`} class="bg-slate-900/50 border border-slate-800 hover:border-slate-600 hover:bg-slate-800 rounded-xl p-6 flex justify-between items-center transition group">
                        <span class="text-xl font-bold text-slate-400 group-hover:text-white transition">{year}</span>
                        <span class="text-slate-600 group-hover:text-blue-400 transition">→</span>
                    </a>
                ))}
            </div>
        </section>
    </main>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            const eventDate = new Date("2026-11-03T09:00:00").getTime();
            
            function updateCountdown() {
                const now = new Date().getTime();
                const diff = eventDate - now;
                const el = document.getElementById('countdown');
                
                if (diff <= 0) {
                    if(el) el.style.display = 'none';
                    return;
                }
                
                if(el) el.classList.remove('hidden');
                
                const days  = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const mins  = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                
                const dEl = document.getElementById('cd-days');
                const hEl = document.getElementById('cd-hours');
                const mEl = document.getElementById('cd-mins');
                
                if(dEl) dEl.textContent = String(days).padStart(2, '0');
                if(hEl) hEl.textContent = String(hours).padStart(2, '0');
                if(mEl) mEl.textContent = String(mins).padStart(2, '0');
            }
            
            updateCountdown();
            setInterval(updateCountdown, 1000);
        });
    </script>
</Layout>

<!-- NEU: CSS für die Ticker-Animation -->
<style>
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-scroll {
        animation: scroll 30s linear infinite;
    }
</style>