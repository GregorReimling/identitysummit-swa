---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tickets | Cloud Identity Summit">
    <!-- Pretix Styles und Scripte laden -->
    <link rel="stylesheet" type="text/css" href="https://pretix.eu/buildclouds/cis2026/widget/v1.css">
    <script type="text/javascript" src="https://pretix.eu/widget/v1.en.js" async></script>

    <main class="max-w-4xl mx-auto px-4 py-32 w-full flex-grow text-center">
        <div class="inline-block bg-blue-900/30 border border-blue-800/50 rounded-full px-4 py-1.5 mb-6">
            <span class="text-blue-400 text-sm font-semibold tracking-wide uppercase">Tickets</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-12">
            Join us in <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">2026</span>
        </h1>

        <!-- Ticket Types Info Grid -->
        <div class="grid md:grid-cols-2 gap-6 mb-12 text-left relative z-10">
            <!-- Community Ticket -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 backdrop-blur-sm relative overflow-hidden">
                <div class="flex justify-between items-start mb-4">
                    <div class="text-3xl">🎟️</div>
                    <span class="bg-slate-800 text-slate-300 border border-slate-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                        Available this Friday
                    </span>
                </div>
                
                <h3 class="text-xl font-bold text-white mb-2">Community Ticket</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-4">
                    Welcome to the Cloud Identity Summit! Get full access to all sessions, networking areas, and catering throughout the day.
                </p>
                <div class="bg-slate-950/50 p-3 rounded-lg border border-slate-800/50">
                    <p class="text-slate-300 text-sm font-medium">
                        ⏱️ Registration opens on Friday, July 17th.
                    </p>
                </div>
            </div>

            <!-- Supporter Ticket -->
            <div class="bg-blue-900/10 border border-blue-500/30 rounded-2xl p-6 backdrop-blur-sm relative overflow-hidden group hover:bg-blue-900/20 transition-colors">
                <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl group-hover:bg-blue-500/20 transition-all"></div>
                
                <div class="flex justify-between items-start mb-4 relative z-10">
                    <div class="text-3xl">🤝</div>
                    <span class="bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide shadow-lg shadow-blue-900/50">Available Now</span>
                </div>
                
                <h3 class="text-xl font-bold text-blue-400 mb-2 relative z-10">Supporter Ticket</h3>
                <p class="text-slate-300 text-sm leading-relaxed mb-4 relative z-10">
                    By purchasing this ticket, you actively support the organisation and operation of this community-driven event.
                </p>
                
                <ul class="text-slate-400 text-sm space-y-2 mb-6 relative z-10">
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">✓</span> <span>Mention during the opening keynote.</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-400">✓</span> <span>Receive an exclusive supporter gift.</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-slate-500">ℹ</span> <span class="text-slate-500 text-xs">Does not guarantee access to specific sessions or reserved seating.</span>
                    </li>
                </ul>
            </div>
        </div>
        
        <!-- Pretix Ticket-Container -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-4 md:p-8 backdrop-blur-sm text-left">
            <pretix-widget event="https://pretix.eu/buildclouds/cis2026/"></pretix-widget>
            
            <noscript>
               <div class="pretix-widget">
                    <div class="pretix-widget-info-message text-slate-300">
                        JavaScript is disabled in your browser. Please <a target="_blank" rel="noopener" href="https://pretix.eu/buildclouds/cis2026/" class="text-blue-400 underline transition-colors">click here</a> to proceed to the ticket shop.
                    </div>
                </div>
            </noscript>
        </div>

        <section class="mt-20 border-t border-slate-800 pt-10 text-center">
            <h3 class="text-xl font-semibold text-white mb-4">Are you a Sponsor?</h3>
            <p class="text-slate-400 mb-6">
                Looking to support the community? Check out our partner packages.
            </p>
            <a href="/call-for-sponsors" class="text-blue-400 hover:text-blue-300 font-medium transition">
                View Sponsor Opportunities →
            </a>
        </section>

        <div class="mt-12">
            <a href="/" class="text-blue-500 hover:text-blue-400 font-semibold transition inline-flex items-center gap-2">
                ← Back to Home
            </a>
        </div>
    </main>
</Layout>